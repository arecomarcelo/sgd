# Configurações do Banco de Dados PostgreSQL
# Local/legado (Streamlit Cloud): IP público da VPS.
# Deploy Docker na VPS (stack.yml): use "host-postgres" — resolvido via
# extra_hosts (host-gateway) para o Postgres nativo do host, sem sair
# para a internet pública (porta 5432 hoje exposta e sob varredura de bots).
DB_NAME=nome_do_banco
DB_USER=usuario_do_banco
DB_PASSWORD=sua_senha_aqui
DB_HOST=ip_ou_host_do_banco
DB_PORT=5432
SECRET_KEY=sua_chave_secreta_aqui
